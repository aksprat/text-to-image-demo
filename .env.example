# Required for DigitalOcean Serverless Inference
MODEL_ACCESS_KEY=your_model_access_key_here

# Inference configuration
INFERENCE_ENDPOINT=https://inference.do-ai.run/v1/async-invoke
MODEL_ID=fal-ai/fast-sdxl

# Spaces configuration
SPACES_ACCESS_KEY=your_spaces_access_key
SPACES_SECRET_KEY=your_spaces_secret_key
SPACES_BUCKET=photosnap-bucket
SPACES_REGION=sgp1
SPACES_FOLDER=generated_images

# Server configuration
PORT=3000
ALLOW_ORIGIN=*
